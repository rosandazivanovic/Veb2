<?xml version="1.0" encoding="utf-8"?>
<StartupServicesManifest xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/2011/01/fabric">
  <Parameters>
    <Parameter Name="ChecklistService_InstanceCount" DefaultValue="-1" />
    <Parameter Name="TravelService_MinReplicaSetSize" DefaultValue="3" />
    <Parameter Name="TravelService_TargetReplicaSetSize" DefaultValue="3" />
    <Parameter Name="UserService_InstanceCount" DefaultValue="-1" />
    <Parameter Name="ApiGateway_InstanceCount" DefaultValue="-1" />
    <Parameter Name="ExpenseService_InstanceCount" DefaultValue="-1" />
  </Parameters>
  <Services>
    <Service Name="TravelService" ServicePackageActivationMode="ExclusiveProcess">
      <StatefulService ServiceTypeName="TravelServiceType" TargetReplicaSetSize="[TravelService_TargetReplicaSetSize]" MinReplicaSetSize="[TravelService_MinReplicaSetSize]">
        <SingletonPartition />
      </StatefulService>
    </Service>
    <Service Name="UserService" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="UserServiceType" InstanceCount="[UserService_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
    <Service Name="ApiGateway" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="ApiGatewayType" InstanceCount="[ApiGateway_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
    <Service Name="ChecklistService" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="ChecklistServiceType" InstanceCount="[ChecklistService_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
    <Service Name="ExpenseService" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="ExpenseServiceType" InstanceCount="[ExpenseService_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
  </Services>
</StartupServicesManifest>